---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Who to Contact" description="Phone numbers, petitions, and direct actions to protect the U.S. Forest Service. Everything you need on one page.">
  <Nav />

  <!-- Hero -->
  <section class="bg-navy py-24">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label">Take Action</p>
      <h1 class="text-5xl md:text-7xl font-black leading-none tracking-tight text-white mb-6">Who to<br />Contact</h1>
      <div class="blue-rule"></div>
      <p class="text-xl text-slate-300 max-w-2xl leading-relaxed mt-6">Seven actions you can take right now from your phone. Calls, petitions, and more — no prep needed.</p>
    </div>
  </section>

  <section class="bg-navy-mid py-16">
    <div class="max-w-3xl mx-auto px-6 space-y-12">

      <!-- Call Your Reps -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5 border-b border-white/10 pb-3">Step 1 — Call Your Representatives</p>
        <div class="space-y-4">

          <div class="card border border-sky/40">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">Capitol Switchboard</p>
                <p class="text-white font-bold text-3xl mb-3"><a href="tel:+12022243121" class="hover:text-sky transition-colors">(202) 224-3121</a></p>
                <p class="text-slate-300 text-sm">Works for everyone in the country. Call and ask to be connected to your senator's or representative's office by name.</p>
              </div>
              <a href="tel:+12022243121" class="btn-primary text-sm shrink-0">Call Now &rarr;</a>
            </div>
          </div>

          <div class="card">
            <p class="text-white font-bold mb-2">Don't know your reps?</p>
            <p class="text-slate-300 text-sm mb-4">Look them up by zip code — you'll get names, direct numbers, and office info.</p>
            <a href="https://www.congress.gov/members/find-your-member" target="_blank" rel="noopener" class="btn-outline text-sm inline-block">Find Your Rep at congress.gov &rarr;</a>
          </div>

        </div>
      </div>

      <!-- California example -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5 border-b border-white/10 pb-3">Example: California (Tahoe-Truckee Area)</p>
        <div class="space-y-4">

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">Sen. Adam Schiff</p>
                <p class="text-white font-bold text-2xl mb-3"><a href="tel:+12022243841" class="hover:text-sky transition-colors">(202) 224-3841</a></p>
                <p class="text-slate-400 text-sm">Leave your name, phone number, CA zip code, and email.</p>
              </div>
              <a href="tel:+12022243841" class="btn-primary text-sm shrink-0">Call &rarr;</a>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">Sen. Alex Padilla</p>
                <p class="text-white font-bold text-2xl mb-3"><a href="tel:+19164482787" class="hover:text-sky transition-colors">(916) 448-2787</a></p>
                <p class="text-slate-400 text-sm">Leave your name and zip code.</p>
              </div>
              <a href="tel:+19164482787" class="btn-primary text-sm shrink-0">Call &rarr;</a>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">Rep. Kevin Kiley</p>
                <p class="text-white font-bold text-2xl mb-3"><a href="tel:+12022252523" class="hover:text-sky transition-colors">(202) 225-2523</a></p>
                <p class="text-slate-400 text-sm">Press 1. Leave your name, email, and phone number.</p>
              </div>
              <a href="tel:+12022252523" class="btn-primary text-sm shrink-0">Call &rarr;</a>
            </div>
          </div>

        </div>
      </div>

      <!-- Sign Petitions -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5 border-b border-white/10 pb-3">Step 2 — Sign Petitions</p>
        <div class="space-y-4">

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">4. Change.org — Stop Glyphosate</p>
                <p class="text-slate-300 text-sm mt-1">Sign the petition against glyphosate spraying in our national forests.</p>
              </div>
              <a href="https://www.change.org/p/stop-glyphosate-spraying-in-the-tahoe-basin" target="_blank" rel="noopener" class="btn-primary text-sm shrink-0">Sign &rarr;</a>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">5. Change.org — Stop the Restructuring</p>
                <p class="text-slate-300 text-sm mt-1">Sign the petition against illegal Forest Service restructuring.</p>
              </div>
              <a href="https://www.change.org/p/don-t-destroy-the-agency-that-protects-america-s-public-lands" target="_blank" rel="noopener" class="btn-primary text-sm shrink-0">Sign &rarr;</a>
            </div>
          </div>

        </div>
      </div>

      <!-- Speak Up Beyond the Call Sheet -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-5 border-b border-white/10 pb-3">Step 3 — Speak Up Beyond the Call</p>
        <div class="space-y-4">

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">6. Tell Outdoor Brands to Speak Out</p>
                <p class="text-slate-300 text-sm mt-1 mb-3">Pressure outdoor companies to use their platforms to defend our public lands.</p>
                <a href="https://saveusfs.org" target="_blank" rel="noopener" class="text-sky font-bold text-sm hover:underline">saveusfs.org &rarr;</a>
              </div>
              <a href="https://saveusfs.org" target="_blank" rel="noopener" class="btn-primary text-sm shrink-0">Take Action &rarr;</a>
            </div>
          </div>

          <div class="card">
            <div class="flex items-start justify-between gap-4 flex-wrap">
              <div>
                <p class="text-sky-bright font-black text-xl mb-1">7. Write a Postcard to a Boise Voter</p>
                <p class="text-slate-300 text-sm mt-1">Ask a Boise voter to call Rep. Mike Simpson (ID-02) about Forest Service cuts. Simpson chairs the House Interior Appropriations Subcommittee — constituent pressure matters.</p>
              </div>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
