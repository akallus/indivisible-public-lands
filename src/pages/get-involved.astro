---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  { name: 'Indivisible Tahoe Truckee', location: 'Truckee / Tahoe, CA', contact: 'IndivisibleTahoeTruckee@gmail.com' },
  { name: 'Northern Nevada Indivisible', location: 'Northern Nevada' },
  { name: 'South Lake Tahoe Indivisible', location: 'South Lake Tahoe, CA' },
  { name: 'Las Vegas Indivisible', location: 'Las Vegas, NV' },
  { name: 'Idaho 50501', location: 'Idaho' },
  { name: 'Indivisible Durango', location: 'Durango, CO' },
  { name: 'Indivisible Bozeman', location: 'Bozeman, MT' },
  { name: 'The Mountain Pact', location: 'Mountain West' },
  { name: 'Indivisible Missoula', location: 'Missoula, MT' },
];
---
<Layout title="Other Ways to Get Involved" description="Letters to the editor, banner events, connecting with partner chapters, and more ways to protect public lands.">
  <Nav />

  <!-- Hero -->
  <section class="bg-navy py-24">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label">Indivisible: Protect Our Forests</p>
      <h1 class="text-5xl md:text-7xl font-black leading-none tracking-tight text-white mb-6">Actions for<br />Your Chapter</h1>
      <div class="blue-rule"></div>
      <p class="text-xl text-slate-300 max-w-2xl leading-relaxed">Not every chapter has a brewery. Not every action needs a bingo card. Here are other high-impact ways your chapter can protect public lands — from letters to the editor to showing up at your representative's office.</p>
    </div>
  </section>

  <!-- Host an Event CTA -->
  <section class="bg-navy-brand py-12">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div>
          <h2 class="text-2xl font-black text-white">Looking for the Democracy on Draft event kit?</h2>
          <p class="text-slate-300 mt-1">Bingo cards, social media copy, a full planning guide — it's all there.</p>
        </div>
        <a href="/host-an-event" class="btn-primary shrink-0">Get the Event Kit &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Letters to the Editor -->
  <section class="bg-navy py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label">Letters to the Editor</p>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">Make Your Voice Heard in Print</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-8 leading-relaxed">Letters to the editor are one of the most effective civic actions available. Congressional staffers read local papers. Editors take notice when a topic generates multiple letters. And your neighbors — especially the ones who aren't on social media — read them too.</p>

      <div class="card mb-8">
        <h3 class="text-white font-black text-xl mb-4">Published: Indivisible Tahoe Truckee in the Sierra Sun</h3>
        <p class="text-slate-400 text-sm mb-4">This letter was published in the Sierra Sun as part of our chapter's Forest Service campaign. Read it, share it, and use it as a template for your own local paper.</p>
        <a href="https://www.sierrasun.com/news/climate-dispatch-the-trump-administration-is-decimating-the-united-states-forest-service-dont-let-them/" target="_blank" rel="noopener" class="btn-primary text-sm">Read the Letter &rarr;</a>
      </div>

      <div class="card">
        <h3 class="text-white font-black text-xl mb-4">How to Write Your Own</h3>
        <div class="space-y-4 text-slate-300 text-sm">
          <div>
            <p class="text-white font-bold mb-1">Keep it short</p>
            <p>Most papers accept 200–300 words. Lead with your local connection — where you live, where you hike, what Forest Service land means to your community.</p>
          </div>
          <div>
            <p class="text-white font-bold mb-1">Be specific and personal</p>
            <p>Name the specific ranger district, the trail, or the watershed that matters to your readers. Specific is more powerful than general.</p>
          </div>
          <div>
            <p class="text-white font-bold mb-1">End with a clear ask</p>
            <p>Tell readers exactly what to do: call their representative, visit 5calls.org, attend your chapter event.</p>
          </div>
          <div>
            <p class="text-white font-bold mb-1">Key facts to include</p>
            <ul class="mt-1 space-y-1 pl-4">
              <li>▸ The Forest Service has lost ~25% of its workforce since January 2025</li>
              <li>▸ The FY26 budget proposes a 65% cut to total Forest Service funding</li>
              <li>▸ 57 of 77 research stations are set to close</li>
              <li>▸ Wildfire prevention work dropped 35–44% in 2025</li>
              <li>▸ The FY27 markup is coming — this is our chance to stop it</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Banner Event -->
  <section class="bg-navy-mid py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label">Banner Actions</p>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">Show Up and Be Visible</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-8 leading-relaxed">Indivisible Tahoe Truckee has hosted banner actions — visible public demonstrations outside congressional offices, community events, and high-traffic locations. They're low-barrier (you just need bodies and a banner), highly visible, and great for local press.</p>

      <div class="card mb-6">
        <h3 class="text-white font-black text-xl mb-3">What We've Done</h3>
        <p class="text-slate-300 text-sm leading-relaxed mb-4">Our chapter organized a banner event to raise visibility around the Forest Service cuts. We can share photos, logistics, and what we learned. If you're considering one in your area, reach out — we'll help you plan it.</p>
        <a href="mailto:IndivisibleTahoeTruckee@gmail.com" class="btn-primary text-sm">Contact Us for Details &rarr;</a>
      </div>

      <div class="card">
        <h3 class="text-white font-black text-xl mb-4">Quick-Start Tips for a Banner Action</h3>
        <ul class="text-slate-300 text-sm space-y-2">
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Pick a high-visibility location: congressional office, farmers market, trailhead, main street corner</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Keep the message simple and readable from a distance: "SAVE THE FOREST SERVICE" / "FUND OUR PUBLIC LANDS"</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Invite your local paper — a photographer showing up makes it count double</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Have a QR code pointing to 5calls.org for passersby to take action on the spot</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Even 6–8 people with matching signs creates a strong visual</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Targeted Actions -->
  <section class="bg-navy py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label">Targeted Actions</p>
      <h2 class="text-3xl font-black text-white mb-3">Target the Decision-Makers</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-8">The House Interior Appropriations Subcommittee is where the FY27 budget gets decided. If your chapter is in one of these districts, you have extra leverage.</p>

      <div class="card mb-6">
        <h3 class="text-white font-bold mb-4">Subcommittee Members — Mixed or Skeptical on Cuts</h3>
        <p class="text-slate-400 text-sm mb-4">These members have shown at least some concern about specific aspects of the restructuring. Constituent pressure from their districts matters most.</p>
        <div class="space-y-3">
          <div class="flex gap-4 items-start">
            <span class="text-sky font-bold text-sm w-36 shrink-0">Mike Simpson (ID)</span>
            <span class="text-slate-300 text-sm">Chair of the subcommittee. Backs HQ move but pushed back on wildfire consolidation: "Congress didn't go along with that." Constituent calls carry extra weight.</span>
          </div>
          <div class="flex gap-4 items-start">
            <span class="text-sky font-bold text-sm w-36 shrink-0">Mark Amodei (NV-2)</span>
            <span class="text-slate-300 text-sm">Called workforce facts "not good" while tracking firings. Also led the public land sale amendment. A neighbor district — worth targeting.</span>
          </div>
          <div class="flex gap-4 items-start">
            <span class="text-sky font-bold text-sm w-36 shrink-0">Ryan Zinke (MT)</span>
            <span class="text-slate-300 text-sm">Led the bipartisan fight to strip Forest Service land sales from the reconciliation bill. Called it a "red line." Co-founded the Public Lands Caucus. Can be pressured further.</span>
          </div>
        </div>
      </div>

      <div class="card">
        <h3 class="text-white font-bold mb-4">Ideas for Actions at Congressional Offices</h3>
        <ul class="text-slate-300 text-sm space-y-2">
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Candlelight vigil for lost Forest Service jobs</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> "Burying the Forest Service" — cover a uniform with dirt as a visual statement</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Picket with lab coats: "Where Is Congress?"</li>
          <li class="flex gap-2"><span class="text-sky mt-0.5">▸</span> Scientist and researcher testimonials on camera at the office steps</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Participating Chapters -->
  <section class="bg-navy-mid py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label">Coalition</p>
      <h2 class="text-3xl font-black text-white mb-3">Chapters Standing Together</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-10">These chapters and organizations joined the Indivisible Tahoe Truckee Forest Service Action meeting on May 7, 2026. If your chapter wants to be listed here, get in touch.</p>
      <div class="grid md:grid-cols-2 gap-4">
        {chapters.map(chapter => (
          <div class="card">
            <p class="text-white font-bold">{chapter.name}</p>
            <p class="text-slate-400 text-sm">{chapter.location}</p>
            {chapter.contact && <a href={`mailto:${chapter.contact}`} class="text-sky text-sm hover:underline mt-1 block">{chapter.contact}</a>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="bg-navy py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <p class="section-label">Connect</p>
      <h2 class="text-3xl font-black text-white mb-4">Get in Touch</h2>
      <div class="blue-rule mx-auto"></div>
      <p class="text-slate-300 mb-8">Want to coordinate with Indivisible Tahoe Truckee? Interested in joining the coalition? Have photos or materials to share? Reach out.</p>
      <a href="mailto:IndivisibleTahoeTruckee@gmail.com" class="btn-primary text-lg px-10 py-5">IndivisibleTahoeTruckee@gmail.com</a>
    </div>
  </section>

  <Footer />
</Layout>
