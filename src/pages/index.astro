---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  'Indivisible Tahoe Truckee',
  'Northern Nevada Indivisible',
  'South Lake Tahoe Indivisible',
  'Las Vegas Indivisible',
  'Idaho 50501',
  'Indivisible Durango',
  'Indivisible Bozeman',
  'The Mountain Pact',
  'Indivisible Missoula',
];
---
<Layout title="Home" description="A free toolkit for Indivisible chapters fighting to protect America's National Forests. Get informed, host an event, and pressure Congress — your chapter can make a difference.">
  <Nav />

  <!-- Hero -->
  <section class="bg-navy min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <p class="section-label">A Free Toolkit for Indivisible Chapters</p>
      <h1 class="text-6xl md:text-8xl font-black leading-none tracking-tight text-white mb-6">
        Your Chapter<br />Can Fight for<br />Our Forests
      </h1>
      <div class="blue-rule"></div>
      <p class="text-lg text-slate-400 max-w-2xl leading-relaxed mb-4">
        The Trump administration has fired thousands of Forest Service workers, proposed a 65% budget cut, and moved to open protected lands to logging, mining, and drilling.
      </p>
      <p class="text-xl md:text-2xl font-bold text-white max-w-3xl mb-4">
        The FY27 budget markup is coming. This is your chapter's moment.
      </p>
      <p class="text-lg text-slate-400 max-w-3xl mb-10">
        We built this free toolkit so any chapter — anywhere — can take action. Get informed. Host an event. Apply pressure. Here's how.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#your-toolkit" class="btn-primary text-lg px-10 py-5">See Your Toolkit &darr;</a>
        <a href="/the-problem" class="btn-outline text-lg px-10 py-5">Read the Full Problem</a>
      </div>
    </div>
  </section>

  <!-- 3-Step Toolkit -->
  <section id="your-toolkit" class="bg-navy-mid py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label text-center">Your Chapter's Toolkit</p>
      <h2 class="text-3xl md:text-4xl font-black text-white text-center mb-3">Three Ways to Take Action</h2>
      <p class="text-slate-300 text-center mb-14 max-w-2xl mx-auto">Everything on this site is free to use and adapt. Start anywhere. Every chapter has something it can do right now.</p>

      <div class="grid md:grid-cols-3 gap-8">

        <!-- Step 1 -->
        <div class="card flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-navy-brand text-sky-bright font-black text-2xl w-12 h-12 rounded-full flex items-center justify-center shrink-0">1</span>
            <p class="text-sky-bright text-xs font-bold uppercase tracking-widest">Get Informed</p>
          </div>
          <h3 class="text-2xl font-black text-white mb-3">Know the Crisis</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 flex-1">
            Understand exactly what's been cut, what's coming, and why it matters to your community. Brief your chapter with the facts — then pass them on.
          </p>
          <div class="space-y-3">
            <a href="/the-problem" class="btn-primary w-full text-center text-sm block">The Full Problem &rarr;</a>
            <a href="/timeline" class="btn-outline w-full text-center text-sm block">Legislative Timeline &rarr;</a>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="card flex flex-col border border-sky/30">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-sky text-white font-black text-2xl w-12 h-12 rounded-full flex items-center justify-center shrink-0">2</span>
            <p class="text-sky-bright text-xs font-bold uppercase tracking-widest">Host an Event</p>
          </div>
          <h3 class="text-2xl font-black text-white mb-1">Democracy on Draft</h3>
          <p class="text-sky-bright text-xs font-bold uppercase tracking-widest mb-3">Event Kit Available</p>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 flex-1">
            A casual evening at a local brewery where neighbors make calls, sign petitions, and go home knowing they did something. We have the full kit: bingo cards, social media copy, and a planning guide.
          </p>
          <a href="/host-an-event" class="btn-primary w-full text-center block">Get the Free Event Kit &rarr;</a>
        </div>

        <!-- Step 3 -->
        <div class="card flex flex-col">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-navy-brand text-sky-bright font-black text-2xl w-12 h-12 rounded-full flex items-center justify-center shrink-0">3</span>
            <p class="text-sky-bright text-xs font-bold uppercase tracking-widest">Go Further</p>
          </div>
          <h3 class="text-2xl font-black text-white mb-3">Actions for Your Chapter</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-6 flex-1">
            Letters to the editor, banner actions at congressional offices, and direct pressure on the committee members who decide the FY27 budget. We've done it — and we'll show you how.
          </p>
          <a href="/get-involved" class="btn-primary w-full text-center block">See All Actions &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Why the Forest Service Matters -->
  <section class="bg-navy-brand py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label text-center">Why It Matters</p>
      <h2 class="text-3xl md:text-4xl font-black text-white text-center mb-3">The Forest Service Is America's Backyard</h2>
      <p class="text-slate-300 text-center mb-14 max-w-2xl mx-auto">193 million acres. 159 million annual visitors. An economic backbone for gateway towns across the country — and it's under threat right now.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <div class="card text-center">
          <p class="stat-number-blue">193M</p>
          <p class="text-white font-bold mt-2">acres managed</p>
          <p class="text-slate-400 text-sm mt-1">National forests & grasslands across all 50 states</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">159M</p>
          <p class="text-white font-bold mt-2">annual visits</p>
          <p class="text-slate-400 text-sm mt-1">Hikers, skiers, hunters, campers & more every year</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">$13.7B</p>
          <p class="text-white font-bold mt-2">contributed to GDP</p>
          <p class="text-slate-400 text-sm mt-1">From visitor spending alone — supports gateway towns</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">161K</p>
          <p class="text-white font-bold mt-2">jobs sustained</p>
          <p class="text-slate-400 text-sm mt-1">In communities near national forests</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">20%</p>
          <p class="text-white font-bold mt-2">of U.S. drinking water</p>
          <p class="text-slate-400 text-sm mt-1">Originates on Forest Service lands</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">11K+</p>
          <p class="text-white font-bold mt-2">wildland firefighters</p>
          <p class="text-slate-400 text-sm mt-1">The nation's largest federal wildfire response force</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Already Happened -->
  <section class="bg-navy py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label">The Crisis</p>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">What's Already Been Done</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-12 max-w-2xl">Since January 2025, the administration has moved fast. Here's what's already happened — and what's still coming.</p>
      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Staffing Gutted</h3>
          <p class="text-slate-300 text-sm leading-relaxed">Over 9,000 Forest Service employees lost through firings and buyouts — about 25% of the workforce — including local Tahoe and Plumas staff. Another 7,000 layoffs are still ahead.</p>
        </div>
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Budget Decimated</h3>
          <p class="text-slate-300 text-sm leading-relaxed">The FY26 budget proposes a 65% cut to total Forest Service funding — $1.4 billion in direct cuts. State, Private & Tribal Forestry funding zeroed out entirely.</p>
        </div>
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Restructuring Underway</h3>
          <p class="text-slate-300 text-sm leading-relaxed">HQ moving from D.C. to Salt Lake City. All 9 regional offices set to close. 57 of 77 research stations shutting down. Local decision-making power is being stripped away.</p>
        </div>
      </div>
      <div class="text-center">
        <a href="/the-problem" class="btn-primary">See the Full Problem &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Who's With Us -->
  <section class="bg-navy-mid py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label text-center">Coalition</p>
      <h2 class="text-3xl font-black text-white text-center mb-4">Chapters Standing Together</h2>
      <p class="text-slate-400 text-center mb-10 text-sm max-w-xl mx-auto">These chapters joined the Indivisible Tahoe Truckee Forest Service Action meeting on May 7, 2026. Want your chapter listed?</p>
      <div class="flex flex-wrap justify-center gap-3">
        {chapters.map(chapter => (
          <span class="bg-navy border border-sky/30 text-slate-300 text-sm font-semibold px-5 py-3 rounded-full">
            {chapter}
          </span>
        ))}
      </div>
      <p class="text-center text-slate-500 text-sm mt-8">Is your chapter involved? <a href="mailto:IndivisibleTahoeTruckee@gmail.com" class="text-sky hover:underline">Get in touch &rarr;</a></p>
    </div>
  </section>

  <Footer />
</Layout>
