---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const chapters = [
  'Indivisible Tahoe Truckee',
  'Northern Nevada Indivisible',
  'South Lake Tahoe Indivisible',
  'Las Vegas Indivisible',
  'Idaho 50501',
  'Indivisible Durango',
  'Indivisible Bozeman',
  'The Mountain Pact',
  'Indivisible Missoula',
];
---
<Layout title="Home" description="A free toolkit for Indivisible chapters fighting to protect America's National Forests. Get informed, host an event, and pressure Congress — your chapter can make a difference.">
  <Nav />

  <!-- Hero -->
  <section class="bg-navy min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-6 py-24 w-full">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="section-label">A Free Toolkit for Indivisible Chapters</p>
          <h1 class="text-5xl md:text-6xl font-black leading-none tracking-tight text-white mb-6">
            Your Chapter<br />Can Fight for<br />Our Forests
          </h1>
          <div class="blue-rule"></div>
          <p class="text-xl md:text-2xl font-bold text-white max-w-xl mb-3">
            Tell Congress: No restructuring, no glyphosate.
          </p>
          <p class="text-base text-slate-300 max-w-xl mb-4 leading-relaxed">
            The fight is not over. Keep the pressure on Congress:
          </p>
          <div class="space-y-2 mb-10 max-w-xl">
            <div class="flex gap-3 items-start bg-navy rounded-lg px-4 py-3">
              <span class="text-sky-bright font-black shrink-0">1</span>
              <p class="text-white text-sm font-semibold leading-snug">Stop the illegal restructuring that guts research and erases decades of institutional knowledge.</p>
            </div>
            <div class="flex gap-3 items-start bg-navy rounded-lg px-4 py-3">
              <span class="text-sky-bright font-black shrink-0">2</span>
              <p class="text-white text-sm font-semibold leading-snug">Stop glyphosate spraying in our national forests.</p>
            </div>
          </div>
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="#your-toolkit" class="btn-primary text-lg px-10 py-5">See Your Toolkit &darr;</a>
            <a href="/the-problem" class="btn-outline text-lg px-10 py-5">Read the Full Problem</a>
          </div>
          <a href="#your-toolkit" class="flex flex-col items-start gap-1 group">
            <p class="text-slate-400 text-sm font-semibold group-hover:text-white transition-colors">6-step action plan below</p>
            <svg class="animate-bounce w-6 h-6 text-sky" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
        <div class="hidden md:block">
          <img
            src="/images/save-the-forest-service-banner-sierra-nevada.jpg"
            alt="Community members hold a 'Save the Forest Service' banner on a highway overpass with the Sierra Nevada mountains in the background"
            class="w-full rounded-2xl shadow-2xl object-cover"
            style="max-height: 500px;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Action Plan -->
  <section id="your-toolkit" class="bg-navy-mid py-20">
    <div class="max-w-4xl mx-auto px-6">
      <p class="section-label text-center">Your Chapter's Action Plan</p>
      <h2 class="text-3xl md:text-4xl font-black text-white text-center mb-14">Six Steps: An Action Plan for Your Chapter</h2>

      <!-- Phase 1 -->
      <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4 border-b border-white/10 pb-3">Your Chapter Acts First</p>
      <div class="space-y-4 mb-10">

        <div class="flex gap-5 items-start bg-navy rounded-xl p-5 border border-sky/40">
          <span class="text-sky-bright font-black text-3xl w-10 shrink-0 leading-none mt-0.5">1</span>
          <div>
            <h3 class="text-white font-black text-xl mb-1">Know the Problem</h3>
            <p class="text-slate-300 text-sm mb-3">Arm your chapter with the facts before you mobilize.</p>
            <div class="flex gap-4 flex-wrap">
              <a href="/the-problem" class="text-sky font-bold text-sm hover:underline">The Problem &rarr;</a>
              <a href="/timeline" class="text-sky font-bold text-sm hover:underline">Full Timeline &rarr;</a>
            </div>
          </div>
        </div>

        <div class="flex gap-5 items-start bg-navy rounded-xl p-5 border-2 border-alert">
          <span class="text-alert font-black text-3xl w-10 shrink-0 leading-none mt-0.5">2</span>
          <div>
            <p class="text-alert text-xs font-black uppercase tracking-widest mb-1">Urgent — Do This Now</p>
            <h3 class="text-white font-black text-xl mb-1">Get Your Chapter to Call Congress</h3>
            <p class="text-slate-300 text-sm mb-3">The House passed its FY27 bill in committee on June 4 — now it heads to the House floor and the Senate. Every member should call their reps this week — it takes 2 minutes.</p>
            <a href="https://www.congress.gov/members/find-your-member" target="_blank" rel="noopener" class="inline-block bg-alert text-white text-sm font-black px-5 py-2 rounded-lg hover:opacity-90 transition-opacity">Call your congressperson &rarr;</a>
          </div>
        </div>

      </div>

      <!-- Phase 2 -->
      <p class="text-xs font-bold uppercase tracking-widest text-slate-500 mb-4 border-b border-white/10 pb-3">Bring Your Community In</p>
      <div class="space-y-4">

        <div class="flex gap-5 items-start">
          <span class="text-sky-bright font-black text-2xl w-8 shrink-0 leading-none mt-0.5">3</span>
          <div>
            <h3 class="text-white font-black text-lg mb-1">Host an Event — Democracy on Draft</h3>
            <p class="text-slate-400 text-sm mb-2">A casual brewery evening where neighbors make calls and go home having done something real. Full kit available.</p>
            <a href="/host-an-event" class="text-sky text-sm font-bold hover:underline">Get the Free Event Kit &rarr;</a>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <span class="text-sky-bright font-black text-2xl w-8 shrink-0 leading-none mt-0.5">4</span>
          <div>
            <h3 class="text-white font-black text-lg mb-1">Write Letters to the Editor</h3>
            <p class="text-slate-400 text-sm mb-2">Local papers reach neighbors who aren't on social — and congressional staffers read them.</p>
            <a href="/get-involved" class="text-sky text-sm font-bold hover:underline">See Example &amp; Tips &rarr;</a>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <span class="text-sky-bright font-black text-2xl w-8 shrink-0 leading-none mt-0.5">5</span>
          <div>
            <h3 class="text-white font-black text-lg mb-1">Banner Action</h3>
            <p class="text-slate-400 text-sm mb-2">Show up at a congressional office or busy corner with a clear message. Low barrier, high visibility.</p>
            <a href="/get-involved" class="text-sky text-sm font-bold hover:underline">Tips &amp; Ideas &rarr;</a>
          </div>
        </div>

        <div class="flex gap-5 items-start">
          <span class="text-sky-bright font-black text-2xl w-8 shrink-0 leading-none mt-0.5">6</span>
          <div>
            <h3 class="text-white font-black text-lg mb-1">Social Media</h3>
            <p class="text-slate-400 text-sm mb-2">Post, share, and tag. Ready-to-use copy you can adapt for your chapter and platforms.</p>
            <a href="/host-an-event#social-copy" class="text-sky text-sm font-bold hover:underline">Get Social Copy &rarr;</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Stop the Dismantling graphic -->
  <section class="bg-alert py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="text-6xl mb-6">🌲</div>
      <h2 class="text-white font-black text-5xl md:text-7xl uppercase leading-tight tracking-tight">
        Call the Senate —<br />That's Where<br />This Stops Now
      </h2>
      <p class="text-red-100 mt-6 text-lg font-semibold max-w-xl mx-auto">The House advanced its FY27 Interior bill on June 4. The fight has moved to the House floor and the Senate — and the Senate is where the restructuring can still be stopped. Two minutes with your senators' offices is the single most effective thing you can do this week.</p>
      <p class="text-red-200 mt-4 text-base italic max-w-xl mx-auto">"I'm a constituent. Please block the Forest Service reorganization in the FY27 bill, make the agency follow the law Congress passed, and don't merge wildland firefighting until the required study is done."</p>
      <a href="https://5calls.org" target="_blank" rel="noopener" class="inline-block mt-8 bg-white text-alert font-black text-lg px-10 py-4 rounded-xl hover:opacity-90 transition-opacity">Call Both Senators &rarr;</a>
    </div>
  </section>

  <!-- Banner photo -->
  <div class="w-full">
    <img
      src="/images/save-the-forest-service-banner-overpass.jpg"
      alt="Indivisible Tahoe Truckee members hold a 'Save the Forest Service' banner on a highway overpass surrounded by pine trees"
      class="w-full object-cover"
      style="max-height: 480px; object-position: center;"
    />
  </div>

  <!-- Why the Forest Service Matters -->
  <section class="bg-navy-brand py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label text-center">Why It Matters</p>
      <h2 class="text-3xl md:text-4xl font-black text-white text-center mb-3">The Forest Service Is America's Backyard</h2>
      <p class="text-slate-300 text-center mb-14 max-w-2xl mx-auto">193 million acres. 159 million annual visitors. An economic backbone for gateway towns across the country — and it's under threat right now.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <div class="card text-center">
          <p class="stat-number-blue">193M</p>
          <p class="text-white font-bold mt-2">acres managed</p>
          <p class="text-slate-400 text-sm mt-1">National forests & grasslands across all 50 states</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">159M</p>
          <p class="text-white font-bold mt-2">annual visits</p>
          <p class="text-slate-400 text-sm mt-1">Hikers, skiers, hunters, campers & more every year</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">$13.7B</p>
          <p class="text-white font-bold mt-2">contributed to GDP</p>
          <p class="text-slate-400 text-sm mt-1">From visitor spending alone — supports gateway towns</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">161K</p>
          <p class="text-white font-bold mt-2">jobs sustained</p>
          <p class="text-slate-400 text-sm mt-1">In communities near national forests</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">20%</p>
          <p class="text-white font-bold mt-2">of U.S. drinking water</p>
          <p class="text-slate-400 text-sm mt-1">Originates on Forest Service lands</p>
        </div>
        <div class="card text-center">
          <p class="stat-number-blue">11K+</p>
          <p class="text-white font-bold mt-2">wildland firefighters</p>
          <p class="text-slate-400 text-sm mt-1">The nation's largest federal wildfire response force</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Already Happened -->
  <section class="bg-navy py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label">The Crisis</p>
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">What's Already Been Done</h2>
      <div class="blue-rule"></div>
      <p class="text-slate-300 mb-12 max-w-2xl">Since January 2025, the administration has moved fast. Here's what's already happened — and what's still coming.</p>
      <div class="grid md:grid-cols-3 gap-6 mb-10">
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Staffing Gutted</h3>
          <p class="text-slate-300 text-sm leading-relaxed">Over 9,000 Forest Service employees lost through firings and buyouts — about 25% of the workforce — including local Tahoe and Plumas staff. Another 7,000 layoffs are still ahead.</p>
        </div>
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Budget Decimated</h3>
          <p class="text-slate-300 text-sm leading-relaxed">The FY26 budget proposes a 65% cut to total Forest Service funding — $1.4 billion in direct cuts. State, Private & Tribal Forestry funding zeroed out entirely.</p>
        </div>
        <div class="card border-l-4 border-alert">
          <h3 class="text-alert font-bold text-lg mb-3">Restructuring Underway</h3>
          <p class="text-slate-300 text-sm leading-relaxed">HQ moving from D.C. to Salt Lake City. All 9 regional offices set to close. 57 of 77 research stations shutting down. Local decision-making power is being stripped away.</p>
        </div>
      </div>
      <div class="text-center">
        <a href="/the-problem" class="btn-primary">See the Full Problem &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Who's With Us -->
  <section class="bg-navy-mid py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="section-label text-center">Coalition</p>
      <h2 class="text-3xl font-black text-white text-center mb-4">Chapters Standing Together</h2>
      <p class="text-slate-400 text-center mb-10 text-sm max-w-xl mx-auto">These chapters joined the Indivisible Tahoe Truckee Forest Service Action meeting on May 7, 2026. Want your chapter listed?</p>
      <div class="flex flex-wrap justify-center gap-3">
        {chapters.map(chapter => (
          <span class="bg-navy border border-sky/30 text-slate-300 text-sm font-semibold px-5 py-3 rounded-full">
            {chapter}
          </span>
        ))}
      </div>
      <p class="text-center text-slate-500 text-sm mt-8">Is your chapter involved? <a href="mailto:IndivisibleTahoeTruckee@gmail.com" class="text-sky hover:underline">Get in touch &rarr;</a></p>
    </div>
  </section>

  <Footer />
</Layout>
