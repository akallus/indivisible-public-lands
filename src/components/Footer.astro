---
const chapters = [
  'Indivisible Tahoe Truckee',
  'Northern Nevada Indivisible',
  'South Lake Tahoe Indivisible',
  'Las Vegas Indivisible',
  'Idaho 50501',
  'Indivisible Durango',
  'Indivisible Bozeman',
  'The Mountain Pact',
  'Indivisible Missoula',
];
---
<footer class="bg-navy-deep border-t border-white/10 pt-16 pb-8">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-sky-bright mb-2">Indivisible Tahoe Truckee</p>
        <p class="text-white font-black text-xl uppercase tracking-wide mb-4">Protect Public Lands</p>
        <p class="text-slate-400 text-sm leading-relaxed">A free action kit for Indivisible chapters and allied organizations. Adapt freely. Share widely. Act urgently.</p>
        <a href="mailto:IndivisibleTahoeTruckee@gmail.com" class="inline-block mt-4 text-sky text-sm hover:underline">IndivisibleTahoeTruckee@gmail.com</a>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-sky-bright mb-4">Pages</p>
        <ul class="space-y-2">
          <li><a href="/" class="text-slate-400 hover:text-white text-sm transition-colors">Home</a></li>
          <li><a href="/the-problem" class="text-slate-400 hover:text-white text-sm transition-colors">The Problem</a></li>
          <li><a href="/timeline" class="text-slate-400 hover:text-white text-sm transition-colors">Timeline</a></li>
          <li><a href="/host-an-event" class="text-slate-400 hover:text-white text-sm transition-colors">Host an Event</a></li>
          <li><a href="/get-involved" class="text-slate-400 hover:text-white text-sm transition-colors">Get Involved</a></li>
        </ul>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-sky-bright mb-4">Key Resources</p>
        <ul class="space-y-2">
          <li><a href="https://5calls.org" target="_blank" rel="noopener" class="text-slate-400 hover:text-white text-sm transition-colors">5calls.org — Call your reps</a></li>
          <li><a href="https://saveusfs.org" target="_blank" rel="noopener" class="text-slate-400 hover:text-white text-sm transition-colors">SaveUSFS.org — Take action</a></li>
          <li><a href="https://outdooralliance.org" target="_blank" rel="noopener" class="text-slate-400 hover:text-white text-sm transition-colors">Outdoor Alliance</a></li>
          <li><a href="https://indivisible.org" target="_blank" rel="noopener" class="text-slate-400 hover:text-white text-sm transition-colors">Indivisible National</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/10 pt-8 text-center">
      <p class="text-slate-500 text-xs">A project of Indivisible Tahoe Truckee. Part of the national Indivisible movement. Content freely shareable for civic use.</p>
    </div>
  </div>
</footer>
